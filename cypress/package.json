{
  "name": "qa-automation-cypress",
  "version": "1.0.0",
  "description": "Cypress UI and API test automation - POM, fixtures, custom commands, Cucumber/BDD and network mocking.",
  "main": "index.js",
  "scripts": {
    "cypress:open": "cypress open",
    "test": "cypress run",
    "test:headed": "npm run test -- --headed",
    "test:chrome": "npm run test -- --browser chrome",
    "test:record": "npm run test -- --record --reporter mochawesome"
  },
  "author": "Lewis Babe Yaka",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^12.8.1",
    "cypress-iframe": "^1.0.1"
  },
  "dependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^16.0.3",
    "@cypress/browserify-preprocessor": "^3.0.2"
  }
}
